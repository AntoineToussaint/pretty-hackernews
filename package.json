{
  "name": "pretty-hackernews",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "bun test",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "css": "tailwindcss -i src/index.css -o src/compiled.css",
    "css:watch": "tailwindcss -i src/index.css -o src/compiled.css --watch",
    "plasmo:dev": "bun run css && (bun run css:watch &) && plasmo dev",
    "plasmo:build": "bun run css && plasmo build",
    "plasmo:zip": "bun run css && plasmo build --zip"
  },
  "displayName": "Pretty Hacker News — a calmer skin for Hacker News",
  "manifest": {
    "host_permissions": [
      "https://news.ycombinator.com/*",
      "https://api.anthropic.com/*",
      "https://api.openai.com/*"
    ],
    "optional_host_permissions": ["*://*/*"],
    "permissions": ["storage", "declarativeNetRequest"]
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "dompurify": "^3.4.7",
    "plasmo": "^0.90.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
